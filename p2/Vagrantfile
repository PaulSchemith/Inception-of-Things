# =============================================================================
# Vagrantfile P2 - Une VM Ubuntu avec K3s + 3 applications + Ingress
#
# ARCHITECTURE :
#   +--------------------------------------------------+
#   |  loginS   192.168.56.110                         |
#   |                                                  |
#   |  K3s server (control plane + worker)             |
#   |                                                  |
#   |  [app1]  [app2 x3 replicas]  [app3]              |
#   |         ↑                                        |
#   |  Traefik Ingress (routage par Host header)       |
#   |    app1.com → app1                               |
#   |    app2.com → app2                               |
#   |    *        → app3 (catch-all)                   |
#   +--------------------------------------------------+
# =============================================================================

Vagrant.configure("2") do |config|
  login       = ENV.fetch("P2_LOGIN", ENV.fetch("USER", "student"))
  server_name = "#{login}S"

  config.vm.box = "generic/ubuntu2204"

  # virtiofs : partage le dossier p2/ avec la VM sous /vagrant.
  # Permet à setup_k3s.sh de lire les manifests depuis /vagrant/confs.
  config.vm.synced_folder ".", "/vagrant", type: "virtiofs"

  config.vm.define server_name do |server|
    server.vm.hostname = server_name
    server.vm.network "private_network", ip: "192.168.56.110"
    server.vm.provider "libvirt" do |lv|
      lv.memory = 1024
      lv.cpus   = 1
      lv.memorybacking :access, :mode => "shared"
    end
    server.vm.provision "shell", path: "scripts/setup_k3s.sh"
  end
end
