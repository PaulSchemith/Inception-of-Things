# =============================================================================
# Vagrantfile P1 - Deux VMs Ubuntu : un serveur K3s + un worker K3s
#
# ARCHITECTURE :
#   +-------------------+          +-------------------+
#   |  loginS           |          |  loginSW          |
#   |  192.168.56.110   |<-------->|  192.168.56.111   |
#   |  K3s SERVER       |  reseau  |  K3s AGENT        |
#   |  (control plane)  |  prive   |  (worker node)    |
#   +-------------------+          +-------------------+
# =============================================================================

Vagrant.configure("2") do |config|
  # Login configurable via la variable d'environnement P1_LOGIN.
  login       = ENV.fetch("P1_LOGIN", ENV.fetch("USER", "student"))
  server_name = "#{login}S"
  worker_name = "#{login}SW"

  config.vm.box = "generic/ubuntu2204"

  # virtiofs : dossier partagé bidirectionnel entre le host et les VMs.
  # Nécessite memorybacking :access, :mode => "shared" dans chaque provider.
  config.vm.synced_folder ".", "/vagrant", type: "virtiofs"

  # === VM 1 : SERVEUR K3s (control plane) ===
  config.vm.define server_name do |server|
    server.vm.hostname = server_name
    server.vm.network "private_network", ip: "192.168.56.110"
    server.vm.provider "libvirt" do |lv|
      lv.memory = 1024
      lv.cpus   = 1
      lv.memorybacking :access, :mode => "shared"
    end
    server.vm.provision "shell", path: "scripts/setup_server.sh"
  end

  # === VM 2 : WORKER K3s (agent) ===
  config.vm.define worker_name do |worker|
    worker.vm.hostname = worker_name
    worker.vm.network "private_network", ip: "192.168.56.111"
    worker.vm.provider "libvirt" do |lv|
      lv.memory = 1024
      lv.cpus   = 1
      lv.memorybacking :access, :mode => "shared"
    end
    worker.vm.provision "shell", path: "scripts/setup_worker.sh"
  end
end
